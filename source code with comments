    // --- MAIN FRAME COMPONENTS ---
    private final InMemoryService service = new InMemoryService(); // Manages all data.
    private final JTextArea      displayArea = new JTextArea();   // Shows output text.
    private final JPanel         centerPanel = new JPanel(new CardLayout()); // Switches between views.
    private final CardLayout     cardLayout = (CardLayout) centerPanel.getLayout();

    public MyFrame3() {
        setTitle("Indian Car Rental System (with Text File Saving)");
        setSize(1000, 700);
        // DO_NOTHING_ON_CLOSE allows us to save data before exiting.
        setDefaultCloseOperation(JFrame.DO_NOTHING_ON_CLOSE);
        // WindowAdapter listens for window‑closing event to save data.
        addWindowListener(new WindowAdapter() {
            @Override
            public void windowClosing(WindowEvent e) {
                service.saveDataToCsv();
                e.getWindow().dispose();
                System.exit(0);
            }
        });
        setLocationRelativeTo(null);
        setLayout(new BorderLayout(5, 5)); // BorderLayout divides window into West, Center, etc.

        String[] menuOptions = {
                "1. List All Cars", "2. List All Customers", "3. Add a New Car", "4. Add a New Customer",
                "5. Rent a Car", "6. Return Car & Get Cost", "7. Delete a Customer",
                "8. List Active Bookings", "9. View Booking & Calc Cost", "10. Exit"
        };
        JList<String> menuList = new JList<>(menuOptions);
        styleMenuList(menuList);
        add(new JScrollPane(menuList), BorderLayout.WEST); // Menu on the left side

        styleDisplayArea();
        centerPanel.add(new JScrollPane(displayArea), "DISPLAY");
        centerPanel.add(createAddCarPanel(),      "ADD_CAR_FORM");
        centerPanel.add(createAddCustomerPanel(), "ADD_CUSTOMER_FORM");
        add(centerPanel, BorderLayout.CENTER);

        // Listener handles menu item selection.
        menuList.addListSelectionListener(e -> {
            if (!e.getValueIsAdjusting()) {
                handleMenuSelection(menuList.getSelectedValue());
                SwingUtilities.invokeLater(menuList::clearSelection);
            }
        });
        displayArea.setText("Welcome! Data loaded from text files.\nPlease select an option.");
    }

    // ------------------- MENU HANDLER -------------------
    // Directs the user to the correct function based on the selected menu option.
    private void handleMenuSelection(String selection) {
        if (selection == null) return;
        styleDisplayArea();
        displayArea.setText("");
        cardLayout.show(centerPanel, "DISPLAY"); // Switch back to the text display view
        String choice = selection.split("\\.")[0]; // Extract number "1" from "1. List All Cars"

        switch (choice) {
            case "1":
            case "2":
            case "8":
                // Change colors for better readability of lists.
                displayArea.setBackground(ColorTheme.LIGHT_YELLOW_BG);
                displayArea.setForeground(Color.BLACK);
                if (choice.equals("1")) getAllCarsAndShow();
                if (choice.equals("2")) getAllCustomersAndShow();
                if (choice.equals("8")) getAllBookingsAndShow();
                break;
            case "3": cardLayout.show(centerPanel, "ADD_CAR_FORM");   break;
            case "4": cardLayout.show(centerPanel, "ADD_CUSTOMER_FORM"); break;
            case "5": rentCar(); break;
            case "6": returnCarAndCalc(); break;
            case "7": deleteCustomer(); break;
            case "9": viewBookingAndCalc(); break;
            case "10":
                service.saveDataToCsv();
                JOptionPane.showMessageDialog(this, "Data saved to text files. Goodbye!",
                        "Goodbye", JOptionPane.INFORMATION_MESSAGE);
                System.exit(0);
                break;
        }
    }

    private void getAllCarsAndShow() {
        service.getAllCars().forEach(c -> displayArea.append(c + "\n"));
    }

    private void getAllCustomersAndShow() {
        service.getAllCustomers().forEach(c -> displayArea.append(c + "\n"));
    }

    private void getAllBookingsAndShow() {
        service.getAllBookings().forEach(b -> displayArea.append(b + "\n"));
    }

    // ------------------- RENT CAR -------------------
    private void rentCar() {
        String carId = JOptionPane.showInputDialog(this, "Enter Car ID to Rent:");
        if (carId == null) return;
        String custId = JOptionPane.showInputDialog(this, "Enter Customer ID:");
        if (custId == null) return;
        String result = service.rentCar(carId, custId);
        JOptionPane.showMessageDialog(this, result);
        handleMenuSelection("1. List All Cars"); // Refresh view to show updated availability
    }

    // ------------------- RETURN CAR & CALCULATE COST -------------------
    private void returnCarAndCalc() {
        String bookingId = JOptionPane.showInputDialog(this, "Enter Booking ID to return:");
        if (bookingId == null) return;
        try {
            String daysStr = JOptionPane.showInputDialog(this, "Enter total days rented:");
            if (daysStr == null) return;
            int days = Integer.parseInt(daysStr);
            String kmStr = JOptionPane.showInputDialog(this, "Enter total kilometers driven:");
            if (kmStr == null) return;
            double kms = Double.parseDouble(kmStr);
            String result = service.returnCarAndCalculateCost(bookingId, days, kms);
            JOptionPane.showMessageDialog(this, result, "Final Cost", JOptionPane.INFORMATION_MESSAGE);
        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this,
                    "Invalid number format for days or kilometers.", "Input Error",
                    JOptionPane.ERROR_MESSAGE);
        }
    }

    // ------------------- DELETE CUSTOMER -------------------
    private void deleteCustomer() {
        String custId = JOptionPane.showInputDialog(this,
                "Enter Customer ID to Delete:", "Delete Customer",
                JOptionPane.WARNING_MESSAGE);
        if (custId != null && !custId.trim().isEmpty()) {
            String result = service.deleteCustomerById(custId);
            JOptionPane.showMessageDialog(this, result, "Deletion Result",
                    JOptionPane.INFORMATION_MESSAGE);
            handleMenuSelection("2. List All Customers");
        }
    }

    // ------------------- VIEW BOOKING & CALC COST -------------------
    private void viewBookingAndCalc() {
        String bookingId = JOptionPane.showInputDialog(this, "Enter Booking ID to view:");
        if (bookingId == null || bookingId.trim().isEmpty()) return;
        Optional<Booking> bookingOpt = service.findBookingById(bookingId);
        if (!bookingOpt.isPresent()) {
            JOptionPane.showMessageDialog(this, "Booking ID not found.", "Error",
                    JOptionPane.ERROR_MESSAGE);
            return;
        }
        Booking booking = bookingOpt.get();

        displayArea.setBackground(ColorTheme.LIGHT_YELLOW_BG);
        displayArea.setForeground(Color.BLACK);
        displayArea.setText("--- Booking Details ---\n");
        displayArea.append("Booking ID: " + booking.id + "\n");
        displayArea.append("Customer: " + booking.customer + "\n");
        displayArea.append("Car: " + booking.car + "\n");

        int choice = JOptionPane.showConfirmDialog(this,
                "Do you want to calculate a potential cost for this booking?",
                "Calculate Cost", JOptionPane.YES_NO_OPTION);
        if (choice != JOptionPane.YES_OPTION) return;

        try {
            String daysStr = JOptionPane.showInputDialog(this, "Enter estimated rental days:");
            if (daysStr == null) return;
            int days = Integer.parseInt(daysStr);
            String kmStr = JOptionPane.showInputDialog(this, "Enter estimated kilometers driven:");
            if (kmStr == null) return;
            double kms = Double.parseDouble(kmStr);
            Car car = booking.car;
            double fixedCost   = days * car.dailyRate;
            double mileageCost = kms * car.perKmRate;
            double totalCost   = fixedCost + mileageCost;
            String result = String.format(
                    "--- Cost Estimation ---\n\nFixed Cost (%d days @ ₹%.2f/day): ₹%.2f\n"
                  + "Mileage Cost (%.1f km @ ₹%.2f/km): ₹%.2f\n"
                  + "-------------------------------------------\nESTIMATED TOTAL: ₹%.2f",
                    days, car.dailyRate, fixedCost,
                    kms,  car.perKmRate,   mileageCost,
                    totalCost
            );
            JOptionPane.showMessageDialog(this, result, "Cost Estimation",
                    JOptionPane.INFORMATION_MESSAGE);
        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this,
                    "Invalid number format for days or kilometers.", "Input Error",
                    JOptionPane.ERROR_MESSAGE);
        }
    }

    // ------------------- CREATE "ADD CAR" FORM -------------------
    private JPanel createAddCarPanel() {
        JPanel panel = createFormPanel();
        JTextField id        = new JTextField();
        JTextField brand     = new JTextField();
        JTextField model     = new JTextField();
        JTextField year      = new JTextField();
        JTextField color     = new JTextField();
        JTextField dailyRate = new JTextField();
        JTextField fuel      = new JTextField();
        JTextField kmRate    = new JTextField();
        JButton    saveButton = new JButton("Save Car");

        addFormField(panel, "ID:", id);
        addFormField(panel, "Brand:", brand);
        addFormField(panel, "Model:", model);
        addFormField(panel, "Year:", year);
        addFormField(panel, "Color:", color);
        addFormField(panel, "Daily Rate (₹):", dailyRate);
        addFormField(panel, "Fuel Type:", fuel);
        addFormField(panel, "Rate per Km (₹):", kmRate);
        panel.add(new JLabel());
        panel.add(saveButton);

        // ActionListener defines what happens when the Save button is clicked.
        saveButton.addActionListener(e -> {
            String carId = id.getText();
            if (carId == null || carId.trim().isEmpty()) {
                JOptionPane.showMessageDialog(this,
                        "Car ID cannot be empty.", "Input Error",
                        JOptionPane.ERROR_MESSAGE);
                return;
            }
            if (service.findCarById(carId).isPresent()) {
                JOptionPane.showMessageDialog(this,
                        "A car with this ID already exists. Please choose a different ID.",
                        "Input Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            try {
                // Add the new car to the service's list.
                service.getAllCars().add(new Car(
                        carId,
                        brand.getText(),
                        model.getText(),
                        Integer.parseInt(year.getText()),
                        color.getText(),
                        Double.parseDouble(dailyRate.getText()),
                        fuel.getText(),
                        Double.parseDouble(kmRate.getText())
                ));
                JOptionPane.showMessageDialog(this, "Car saved successfully!");
                handleMenuSelection("1. List All Cars");
            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(this,
                        "Error: Please check the format for Year, Daily Rate, and Km Rate.",
                        "Input Error", JOptionPane.ERROR_MESSAGE);
            }
        });
        return panel;
    }

