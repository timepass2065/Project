            handleMenuSelection("2. List All Customers");
        });
        return panel;
    }

    // ------------------- FORM HELPERS -------------------
    // Standardises appearance of all forms.
    private JPanel createFormPanel() {
        JPanel panel = new JPanel(new GridLayout(0, 2, 10, 10)); // 2 columns, auto-calc rows
        panel.setBackground(ColorTheme.DISPLAY_BACKGROUND);
        panel.setBorder(new EmptyBorder(20, 20, 20, 20));
        return panel;
    }

    // Adds a label + input component pair to a form.
    private void addFormField(JPanel panel, String label, JComponent component) {
        JLabel l = new JLabel(label);
        l.setForeground(ColorTheme.FOREGROUND);
        panel.add(l);
        panel.add(component);
    }

    // Styles the menu list for a consistent theme.
    private void styleMenuList(JList<String> list) {
        list.setBackground(ColorTheme.MENU_BACKGROUND);
        list.setForeground(ColorTheme.FOREGROUND);
        list.setSelectionBackground(ColorTheme.ACCENT_COLOR);
        list.setSelectionForeground(ColorTheme.BACKGROUND);
        list.setFixedCellHeight(40);
        list.setFont(new Font("SansSerif", Font.BOLD, 14));
        list.setBorder(new EmptyBorder(10, 15, 10, 15));
    }

    // Styles the main display text area.
    private void styleDisplayArea() {
        displayArea.setBackground(ColorTheme.DISPLAY_BACKGROUND);
        displayArea.setForeground(ColorTheme.FOREGROUND);
        displayArea.setFont(new Font("Monospaced", Font.BOLD, 14));
        displayArea.setEditable(false);               // Prevent user from typing in output area
        displayArea.setMargin(new Insets(15, 15, 15, 15));
    }

   // ------------------- APPLICATION ENTRY POINT -------------------
public static void main(String[] args) {
    // Set consistent colours for dialog boxes (JOptionPane)
    UIManager.put("OptionPane.background", ColorTheme.BACKGROUND);
    UIManager.put("Panel.background",       ColorTheme.BACKGROUND);
    UIManager.put("OptionPane.messageForeground", ColorTheme.FOREGROUND);

    EntryScreen entryScreen = new EntryScreen();
    entryScreen.setVisible(true);

    // Timer creates the animation effect for the progress bar (runs every 30 ms)
    Timer timer = new Timer(30, new ActionListener() {
        private int progress = 0;  
        @Override
        public void actionPerformed(ActionEvent e) {
            progress++;
            entryScreen.setProgress(progress);
            if (progress >= 100) {
                ((Timer) e.getSource()).stop(); // Stop timer when done
                entryScreen.dispose();           // Close splash screen
                // Open main application window on the Event Dispatch Thread
                SwingUtilities.invokeLater(() -> new MyFrame3().setVisible(true));
            }
        }
    });
    timer.start();
}

