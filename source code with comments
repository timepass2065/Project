    // --- SERVICE LAYER (BUSINESS LOGIC) ---
    // This class handles all data operations (CRUD) and file persistence.
    // It separates logic from the UI (Model‑View‑Controller principle).
    private static class InMemoryService {
        private List<Car>      cars      = new ArrayList<>();
        private List<Customer> customers = new ArrayList<>();
        private List<Booking>  bookings  = new ArrayList<>();
        // AtomicInteger is used here for thread‑safe ID generation.
        private AtomicInteger bookingIdCounter;

        public InMemoryService() { 
            System.out.println("Working Directory: " + System.getProperty("user.dir")); // DEBUG: Shows where files are saved
            loadDataFromCsv(); 
        }

        // --------------------------------------------------------------------
        // Reads all CSV files (cars, customers, bookings) into memory.
        // --------------------------------------------------------------------
        private void loadDataFromCsv() {
            File carsFile = new File("cars.csv");
            // If files don't exist, this is the first run → create default data.
            if (!carsFile.exists()) {
                System.out.println("No data files found. Creating default data and files.");
                populateInitialData();
                saveDataToCsv();                     // Create the files for the first time
                return;
            }

            // ----- Load Cars -----
            try (BufferedReader br = new BufferedReader(new FileReader("cars.csv"))) {
                String line;
                while ((line = br.readLine()) != null) {
                    String[] values = line.split(",");
                    Car car = new Car(
                            values[0],                                 // id
                            values[1],                                 // brand
                            values[2],                                 // model
                            Integer.parseInt(values[3]),               // year
                            values[4],                                 // color
                            Double.parseDouble(values[5]),             // dailyRate
                            values[6],                                 // fuelType
                            Double.parseDouble(values[7])              // perKmRate
                    );
                    car.isAvailable = Boolean.parseBoolean(values[8]);
                    cars.add(car);
                }
            } catch (IOException e) {
                System.err.println("Error loading cars.csv: " + e.getMessage());
            } catch (NumberFormatException e) {
                System.err.println("Error parsing cars.csv data: " + e.getMessage());
            }

            // ----- Load Customers -----
            try (BufferedReader br = new BufferedReader(new FileReader("customers.csv"))) {
                String line;
                while ((line = br.readLine()) != null) {
                    String[] values = line.split(",");
                    customers.add(new Customer(values[0], values[1], values[2]));
                }
            } catch (IOException e) {
                System.err.println("Error loading customers.csv: " + e.getMessage());
            }

            // ----- Load Bookings -----
            try (BufferedReader br = new BufferedReader(new FileReader("bookings.csv"))) {
                String line;
                while ((line = br.readLine()) != null) {
                    String[] values = line.split(",");
                    String bookingId = values[0];
                    Optional<Car> car        = findCarById(values[1]);
                    Optional<Customer> cust  = findCustomerById(values[2]);
                    // Only add the booking if both car and customer exist (data integrity).
                    if (car.isPresent() && cust.isPresent()) {
                        bookings.add(new Booking(bookingId, car.get(), cust.get()));
                    }
                }
            } catch (IOException e) {
                System.err.println("Error loading bookings.csv: " + e.getMessage());
            }

            // Determine the next booking ID by looking at the highest existing ID.
            int maxId = bookings.stream()
                    .map(b -> b.id.replace("B", ""))   // Remove the "B" prefix
                    .mapToInt(Integer::parseInt)      // Convert to integer
                    .max()
                    .orElse(100);                     // Default start if no bookings
            bookingIdCounter = new AtomicInteger(maxId + 1);  // FIXED: Start from next ID
        }

        // --------------------------------------------------------------------
        // Saves current memory data back to CSV files (persistence).
        // --------------------------------------------------------------------
        public void saveDataToCsv() {
            // ----- Save Cars -----
            try (PrintWriter pw = new PrintWriter(new FileWriter("cars.csv"))) {
                for (Car car : cars) {
                    pw.println(String.join(",",
                            car.id,
                            car.brand,
                            car.model,
                            String.valueOf(car.year),
                            car.color,
                            String.valueOf(car.dailyRate),
                            car.fuelType,
                            String.valueOf(car.perKmRate),
                            String.valueOf(car.isAvailable)
                    ));
                }
            } catch (IOException e) {
                System.err.println("Error saving cars.csv: " + e.getMessage());
            }

            // ----- Save Customers -----
            try (PrintWriter pw = new PrintWriter(new FileWriter("customers.csv"))) {
                for (Customer cust : customers) {
                    pw.println(String.join(",", cust.id, cust.name, cust.email));
                }
            } catch (IOException e) {
                System.err.println("Error saving customers.csv: " + e.getMessage());
            }

            // ----- Save Bookings -----
            try (PrintWriter pw = new PrintWriter(new FileWriter("bookings.csv"))) {
                for (Booking b : bookings) {
                    // Store only IDs – objects are linked in memory.
                    pw.println(String.join(",", b.id, b.car.id, b.customer.id));
                }
            } catch (IOException e) {
                System.err.println("Error saving bookings.csv: " + e.getMessage());
            }
            
            System.out.println("Data saved successfully to CSV files.");
        }

        // --------------------------------------------------------------------
        // Creates sample data for demonstration if no files exist.
        // --------------------------------------------------------------------
        private void populateInitialData() {
            cars.add(new Car("C01", "Maruti",    "Swift",      2023, "Red",    2500.0, "Petrol",   11.0));
            cars.add(new Car("C02", "Hyundai",   "Creta",      2022, "White",  3500.0, "Diesel",   14.0));
            cars.add(new Car("C03", "Tata",      "NexonEV",    2024, "Blue",   4000.0, "Electric", 15.0));

            customers.add(new Customer("U01", "Modiji",          "modi@example.com"));
            customers.add(new Customer("U02", "Rahul gandhi",   "rahul@example.com"));

            bookingIdCounter = new AtomicInteger(100);
        }

        // --------------------------------------------------------------------
        // Getters provide read‑only access to the internal lists.
        // --------------------------------------------------------------------
        public List<Car>      getAllCars()      { return cars; }
        public List<Customer> getAllCustomers() { return customers; }
        public List<Booking>  getAllBookings()  { return bookings; }

        // --------------------------------------------------------------------
        // Uses Stream API to find an element by its ID.
        // --------------------------------------------------------------------
        public Optional<Car>      findCarById(String id)      { return cars.stream().filter(c -> c.id.equalsIgnoreCase(id)).findFirst(); }
        public Optional<Car>      findAvailableCarById(String id) { return cars.stream().filter(c -> c.id.equalsIgnoreCase(id) && c.isAvailable).findFirst(); }
        public Optional<Customer> findCustomerById(String id) { return customers.stream().filter(c -> c.id.equalsIgnoreCase(id)).findFirst(); }
        public Optional<Booking>  findBookingById(String id)  { return bookings.stream().filter(b -> b.id.equalsIgnoreCase(id)).findFirst(); }

        // --------------------------------------------------------------------
        // Core Business Logic – Renting a Car.
        // --------------------------------------------------------------------
        public String rentCar(String carId, String customerId) {
            Optional<Car> carOpt = findAvailableCarById(carId);
            if (!carOpt.isPresent()) return "Car not available or does not exist.";
            if (!findCustomerById(customerId).isPresent()) return "Customer does not exist.";

            carOpt.get().isAvailable = false;                     // Mark car as unavailable.
            String bookingId = "B" + bookingIdCounter.incrementAndGet(); // Generate unique ID.
            bookings.add(new Booking(bookingId, carOpt.get(), findCustomerById(customerId).get()));
            return "Car rented successfully! Booking ID: " + bookingId;
        }

        // --------------------------------------------------------------------
        // Core Business Logic – Returning a Car & Billing.
        // --------------------------------------------------------------------
        public String returnCarAndCalculateCost(String bookingId, int daysRented, double kmDriven) {
            Optional<Booking> bookingOpt = findBookingById(bookingId);
            if (!bookingOpt.isPresent()) return "Error: Booking ID not found.";
            Booking booking = bookingOpt.get();
            Car car = booking.car;
            if (car.isAvailable) return "Error: This car has already been returned.";

            double fixedCost   = daysRented * car.dailyRate;
            double mileageCost = kmDriven * car.perKmRate;
            double totalCost   = fixedCost + mileageCost;

            car.isAvailable = true;               // Car becomes available again.
            bookings.remove(booking);              // Remove the completed booking.

            return String.format(
                    "Return Successful!\n\nFixed Cost (%d days @ ₹%.2f/day): ₹%.2f\n"
                  + "Mileage Cost (%.1f km @ ₹%.2f/km): ₹%.2f\n"
                  + "-------------------------------------------\nTOTAL COST: ₹%.2f",
                    daysRented, car.dailyRate, fixedCost,
                    kmDriven, car.perKmRate, mileageCost,
                    totalCost
            );
        }

        // --------------------------------------------------------------------
        // Delete a customer – allowed only when they have no active bookings.
        // --------------------------------------------------------------------
        public String deleteCustomerById(String customerId) {
            Optional<Customer> custOpt = findCustomerById(customerId);
            if (!custOpt.isPresent()) return "Customer not found.";
            boolean hasActiveBooking = bookings.stream()
                    .anyMatch(b -> b.customer.id.equalsIgnoreCase(customerId));
            if (hasActiveBooking) return "Error: Customer cannot be deleted as they have an active rental.";
            customers.remove(custOpt.get());
            return "Customer " + custOpt.get().name + " deleted successfully.";
        }
    }

