    private final InMemoryService service = new InMemoryService();
    private final JTextArea displayArea = new JTextArea();
    private final JPanel centerPanel = new JPanel(new CardLayout());
    private final CardLayout cardLayout = (CardLayout) centerPanel.getLayout();

    public MyFrame3() {
        setTitle("Indian Car Rental System (with Text File Saving)");
        setSize(1000, 700);
        setDefaultCloseOperation(JFrame.DO_NOTHING_ON_CLOSE);
        addWindowListener(new WindowAdapter() {
            @Override
            public void windowClosing(WindowEvent e) {
                service.saveDataToCsv(); e.getWindow().dispose(); System.exit(0);
            }
        });
        setLocationRelativeTo(null);
        setLayout(new BorderLayout(5, 5));
        String[] menuOptions = {
            "1. List All Cars", "2. List All Customers", "3. Add a New Car", "4. Add a New Customer",
            "5. Rent a Car", "6. Return Car & Get Cost", "7. Delete a Customer",
            "8. List Active Bookings", "9. View Booking & Calc Cost", "10. Exit"
        };
        JList<String> menuList = new JList<>(menuOptions); styleMenuList(menuList);
        add(new JScrollPane(menuList), BorderLayout.WEST);
        styleDisplayArea();
        centerPanel.add(new JScrollPane(displayArea), "DISPLAY");
        centerPanel.add(createAddCarPanel(), "ADD_CAR_FORM");
        centerPanel.add(createAddCustomerPanel(), "ADD_CUSTOMER_FORM");
        add(centerPanel, BorderLayout.CENTER);
        menuList.addListSelectionListener(e -> {
            if (!e.getValueIsAdjusting()) {
                handleMenuSelection(menuList.getSelectedValue());
                SwingUtilities.invokeLater(menuList::clearSelection);
            }
        });
        displayArea.setText("Welcome! Data loaded from text files.\nPlease select an option.");
    }

    private void handleMenuSelection(String selection) {
        if (selection == null) return;
        styleDisplayArea(); displayArea.setText("");
        cardLayout.show(centerPanel, "DISPLAY");
        String choice = selection.split("\\.")[0];
        switch (choice) {
            case "1": case "2": case "8":
                displayArea.setBackground(ColorTheme.LIGHT_YELLOW_BG); displayArea.setForeground(Color.BLACK);
                if (choice.equals("1")) service.getAllCars().forEach(c -> displayArea.append(c + "\n"));
                if (choice.equals("2")) service.getAllCustomers().forEach(c -> displayArea.append(c + "\n"));
                if (choice.equals("8")) service.getAllBookings().forEach(b -> displayArea.append(b + "\n"));
                break;
            case "3": cardLayout.show(centerPanel, "ADD_CAR_FORM"); break;
            case "4": cardLayout.show(centerPanel, "ADD_CUSTOMER_FORM"); break;
            case "5": rentCar(); break;
            case "6": returnCarAndCalc(); break;
            case "7": deleteCustomer(); break;
            case "9": viewBookingAndCalc(); break;
            case "10":
                service.saveDataToCsv();
                JOptionPane.showMessageDialog(this, "Data saved to text files. Goodbye!", "Goodbye", JOptionPane.INFORMATION_MESSAGE);
                System.exit(0);
                break;
        }
    }
    
    private void rentCar() {
        String carId = JOptionPane.showInputDialog(this, "Enter Car ID to Rent:"); if (carId == null) return;
        String custId = JOptionPane.showInputDialog(this, "Enter Customer ID:"); if (custId == null) return;
        String result = service.rentCar(carId, custId);
        JOptionPane.showMessageDialog(this, result);
        handleMenuSelection("1. List All Cars");
    }

    private void returnCarAndCalc() {
        String bookingId = JOptionPane.showInputDialog(this, "Enter Booking ID to return:");
        if (bookingId == null) return;
        try {
            String daysStr = JOptionPane.showInputDialog(this, "Enter total days rented:");
            if (daysStr == null) return;
            int days = Integer.parseInt(daysStr);
            String kmStr = JOptionPane.showInputDialog(this, "Enter total kilometers driven:");
            if (kmStr == null) return;
            double kms = Double.parseDouble(kmStr);
            String result = service.returnCarAndCalculateCost(bookingId, days, kms);
            JOptionPane.showMessageDialog(this, result, "Final Cost", JOptionPane.INFORMATION_MESSAGE);
        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, "Invalid number format for days or kilometers.", "Input Error", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private void deleteCustomer() {
        String custId = JOptionPane.showInputDialog(this, "Enter Customer ID to Delete:", "Delete Customer", JOptionPane.WARNING_MESSAGE);
        if (custId != null && !custId.trim().isEmpty()) {
            String result = service.deleteCustomerById(custId);
            JOptionPane.showMessageDialog(this, result, "Deletion Result", JOptionPane.INFORMATION_MESSAGE);
            handleMenuSelection("2. List All Customers");
        }
    }

    private void viewBookingAndCalc() {
        String bookingId = JOptionPane.showInputDialog(this, "Enter Booking ID to view:");
        if (bookingId == null || bookingId.trim().isEmpty()) return;
        Optional<Booking> bookingOpt = service.findBookingById(bookingId);
        if (!bookingOpt.isPresent()) {
            JOptionPane.showMessageDialog(this, "Booking ID not found.", "Error", JOptionPane.ERROR_MESSAGE);
            return;
        }
        Booking booking = bookingOpt.get();
        displayArea.setBackground(ColorTheme.LIGHT_YELLOW_BG);
        displayArea.setForeground(Color.BLACK);
        displayArea.setText("--- Booking Details ---\n");
        displayArea.append("Booking ID: " + booking.id + "\n");
        displayArea.append("Customer: " + booking.customer.toString() + "\n");
        displayArea.append("Car: " + booking.car.toString() + "\n");
        int choice = JOptionPane.showConfirmDialog(this, "Do you want to calculate a potential cost for this booking?", "Calculate Cost", JOptionPane.YES_NO_OPTION);
        if (choice != JOptionPane.YES_OPTION) return;
        try {
            String daysStr = JOptionPane.showInputDialog(this, "Enter estimated rental days:"); if (daysStr == null) return;
            int days = Integer.parseInt(daysStr);
            String kmStr = JOptionPane.showInputDialog(this, "Enter estimated kilometers driven:"); if (kmStr == null) return;
            double kms = Double.parseDouble(kmStr);
            Car car = booking.car;
            double fixedCost = days * car.dailyRate;
            double mileageCost = kms * car.perKmRate;
            double totalCost = fixedCost + mileageCost;
            String result = String.format("--- Cost Estimation ---\n\nFixed Cost (%d days @ ₹%.2f/day): ₹%.2f\nMileage Cost (%.1f km @ ₹%.2f/km): ₹%.2f\n-------------------------------------------\nESTIMATED TOTAL: ₹%.2f",
                days, car.dailyRate, fixedCost, kms, car.perKmRate, mileageCost, totalCost);
            JOptionPane.showMessageDialog(this, result, "Cost Estimation", JOptionPane.INFORMATION_MESSAGE);
        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, "Invalid number format for days or kilometers.", "Input Error", JOptionPane.ERROR_MESSAGE);
        }
    }

    private JPanel createAddCarPanel() {
        JPanel panel = createFormPanel();
        JTextField id = new JTextField(), brand = new JTextField(), model = new JTextField(), year = new JTextField();
        JTextField color = new JTextField(), dailyRate = new JTextField(), fuel = new JTextField(), kmRate = new JTextField();
        JButton saveButton = new JButton("Save Car");
        
        addFormField(panel, "ID:", id); addFormField(panel, "Brand:", brand); addFormField(panel, "Model:", model);
        addFormField(panel, "Year:", year); addFormField(panel, "Color:", color);
        addFormField(panel, "Daily Rate (₹):", dailyRate);
        addFormField(panel, "Fuel Type:", fuel); addFormField(panel, "Rate per Km (₹):", kmRate);
        panel.add(new JLabel()); panel.add(saveButton);
        
        saveButton.addActionListener(e -> {
            String carId = id.getText();
            if (carId == null || carId.trim().isEmpty()) {
                JOptionPane.showMessageDialog(this, "Car ID cannot be empty.", "Input Error", JOptionPane.ERROR_MESSAGE); return;
            }
            if (service.findCarById(carId).isPresent()) {
                JOptionPane.showMessageDialog(this, "A car with this ID already exists. Please choose a different ID.", "Input Error", JOptionPane.ERROR_MESSAGE); return;
            }
            try {
                service.cars.add(new Car(carId, brand.getText(), model.getText(), Integer.parseInt(year.getText()), color.getText(), Double.parseDouble(dailyRate.getText()), fuel.getText(), Double.parseDouble(kmRate.getText())));
                JOptionPane.showMessageDialog(this, "Car saved successfully!");
                handleMenuSelection("1. List All Cars");
            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(this, "Error: Please check the format for Year, Daily Rate, and Km Rate.", "Input Error", JOptionPane.ERROR_MESSAGE);
            }
        });
        return panel;
    }

    private JPanel createAddCustomerPanel() {
        JPanel panel = createFormPanel();
        JTextField id = new JTextField(), name = new JTextField(), email = new JTextField();
        JButton saveButton = new JButton("Save Customer");
        
        addFormField(panel, "ID:", id); addFormField(panel, "Name:", name); addFormField(panel, "Email:", email);
        panel.add(new JLabel()); panel.add(saveButton);
        
        saveButton.addActionListener(e -> {
            String custId = id.getText();
            if (custId == null || custId.trim().isEmpty()) {
                JOptionPane.showMessageDialog(this, "Customer ID cannot be empty.", "Input Error", JOptionPane.ERROR_MESSAGE); return;
            }
            if (service.findCustomerById(custId).isPresent()) {
                JOptionPane.showMessageDialog(this, "A customer with this ID already exists. Please choose a different ID.", "Input Error", JOptionPane.ERROR_MESSAGE); return;
            }
            service.customers.add(new Customer(custId, name.getText(), email.getText()));
            JOptionPane.showMessageDialog(this, "Customer saved successfully!");
            handleMenuSelection("2. List All Customers");
        });
        return panel;
    }

    private JPanel createFormPanel() {
        JPanel panel = new JPanel(new GridLayout(0, 2, 10, 10));
        panel.setBackground(ColorTheme.DISPLAY_BACKGROUND);
        panel.setBorder(new EmptyBorder(20, 20, 20, 20));
        return panel;
    }

    private void addFormField(JPanel panel, String label, JComponent component) {
        JLabel l = new JLabel(label);
        l.setForeground(ColorTheme.FOREGROUND);
        panel.add(l);
        panel.add(component);
    }
    
    private void styleMenuList(JList<String> list) {
        list.setBackground(ColorTheme.MENU_BACKGROUND);
        list.setForeground(ColorTheme.FOREGROUND);
        list.setSelectionBackground(ColorTheme.ACCENT_COLOR);
        list.setSelectionForeground(ColorTheme.BACKGROUND);
        list.setFixedCellHeight(40);
        list.setFont(new Font("SansSerif", Font.BOLD, 14));
        list.setBorder(new EmptyBorder(10, 15, 10, 15));
    }
    
    private void styleDisplayArea() {
        displayArea.setBackground(ColorTheme.DISPLAY_BACKGROUND);
        displayArea.setForeground(ColorTheme.FOREGROUND);
        displayArea.setFont(new Font("Monospaced", Font.BOLD, 14));
        displayArea.setEditable(false);
        displayArea.setMargin(new Insets(15, 15, 15, 15));
    }
    
    public static void main(String[] args) {
        UIManager.put("OptionPane.background", ColorTheme.BACKGROUND);
        UIManager.put("Panel.background", ColorTheme.BACKGROUND);
        UIManager.put("OptionPane.messageForeground", ColorTheme.FOREGROUND);
        EntryScreen entryScreen = new EntryScreen();
        entryScreen.setVisible(true);
        Timer timer = new Timer(30, new ActionListener() {
            private int progress = 0;
            @Override
            public void actionPerformed(ActionEvent e) {
                progress++;
                entryScreen.setProgress(progress);
                if (progress >= 100) {
                    ((Timer) e.getSource()).stop();
                    entryScreen.dispose();
                    SwingUtilities.invokeLater(() -> new MyFrame3().setVisible(true));
                }
            }
        });
        timer.start();
    }
