    // --- Data Model Classes (Serializable is no longer needed) ---
    private static class Car {
        String id, brand, model, color, fuelType;
        int year;
        double dailyRate, perKmRate;
        boolean isAvailable = true;

        public Car(String id, String brand, String model, int year, String color, double dailyRate, String fuelType, double perKmRate) {
            this.id = id; this.brand = brand; this.model = model; this.year = year; this.color = color;
            this.dailyRate = dailyRate; this.fuelType = fuelType; this.perKmRate = perKmRate;
        }

        @Override
        public String toString() {
            return String.format("ID: %s | %s %s (%d) | Day: ₹%.2f | Km: ₹%.2f | %s",
                id, brand, model, year, dailyRate, perKmRate, isAvailable ? "Available" : "Rented");
        }
    }

    private static class Customer {
        String id, name, email;
        public Customer(String id, String name, String email) { this.id = id; this.name = name; this.email = email; }
        @Override public String toString() { return String.format("ID: %s | Name: %s | Email: %s", id, name, email); }
    }

    private static class Booking {
        String id; Car car; Customer customer;
        public Booking(String id, Car car, Customer customer) { this.id = id; this.car = car; this.customer = customer; }
        @Override public String toString() { return String.format("Booking %s: %s rented by %s", id, car.brand, customer.name); }
    }

    // --- Service COMPLETELY REWRITTEN to use CSV text files ---
    private static class InMemoryService {
        private List<Car> cars = new ArrayList<>();
        private List<Customer> customers = new ArrayList<>();
        private List<Booking> bookings = new ArrayList<>();
        private AtomicInteger bookingIdCounter;

        public InMemoryService() {
            loadDataFromCsv();
        }
        
        private void loadDataFromCsv() {
            File carsFile = new File("cars.csv");
            if (!carsFile.exists()) {
                System.out.println("No data files found. Creating default data and files.");
                populateInitialData();
                saveDataToCsv(); // Create the files for the first time
                return;
            }

            // --- Load Cars ---
            try (BufferedReader br = new BufferedReader(new FileReader("cars.csv"))) {
                String line;
                while ((line = br.readLine()) != null) {
                    String[] values = line.split(",");
                    Car car = new Car(values[0], values[1], values[2], Integer.parseInt(values[3]), values[4], Double.parseDouble(values[5]), values[6], Double.parseDouble(values[7]));
                    car.isAvailable = Boolean.parseBoolean(values[8]);
                    cars.add(car);
                }
            } catch (IOException e) { System.err.println("Error loading cars.csv: " + e.getMessage()); }

            // --- Load Customers ---
            try (BufferedReader br = new BufferedReader(new FileReader("customers.csv"))) {
                String line;
                while ((line = br.readLine()) != null) {
                    String[] values = line.split(",");
                    customers.add(new Customer(values[0], values[1], values[2]));
                }
            } catch (IOException e) { System.err.println("Error loading customers.csv: " + e.getMessage()); }

            // --- Load Bookings ---
            try (BufferedReader br = new BufferedReader(new FileReader("bookings.csv"))) {
                String line;
                while ((line = br.readLine()) != null) {
                    String[] values = line.split(",");
                    String bookingId = values[0];
                    Optional<Car> car = findCarById(values[1]);
                    Optional<Customer> customer = findCustomerById(values[2]);
                    if (car.isPresent() && customer.isPresent()) {
                        bookings.add(new Booking(bookingId, car.get(), customer.get()));
                    }
                }
            } catch (IOException e) { System.err.println("Error loading bookings.csv: " + e.getMessage()); }
            
            // Recalculate the booking counter
            int maxId = bookings.stream()
                .map(b -> b.id.replace("B", ""))
                .mapToInt(Integer::parseInt)
                .max().orElse(100);
            bookingIdCounter = new AtomicInteger(maxId);
        }

        public void saveDataToCsv() {
            // --- Save Cars ---
            try (PrintWriter pw = new PrintWriter(new FileWriter("cars.csv"))) {
                for (Car car : cars) {
                    pw.println(String.join(",", car.id, car.brand, car.model, String.valueOf(car.year), car.color, String.valueOf(car.dailyRate), car.fuelType, String.valueOf(car.perKmRate), String.valueOf(car.isAvailable)));
                }
            } catch (IOException e) { System.err.println("Error saving cars.csv: " + e.getMessage()); }
            
            // --- Save Customers ---
            try (PrintWriter pw = new PrintWriter(new FileWriter("customers.csv"))) {
                for (Customer customer : customers) {
                    pw.println(String.join(",", customer.id, customer.name, customer.email));
                }
            } catch (IOException e) { System.err.println("Error saving customers.csv: " + e.getMessage()); }

            // --- Save Bookings ---
            try (PrintWriter pw = new PrintWriter(new FileWriter("bookings.csv"))) {
                for (Booking booking : bookings) {
                    pw.println(String.join(",", booking.id, booking.car.id, booking.customer.id));
                }
            } catch (IOException e) { System.err.println("Error saving bookings.csv: " + e.getMessage()); }
        }
        
        // --- THIS METHOD HAS BEEN CHANGED ---
        private void populateInitialData() {
            cars.add(new Car("C01", "Maruti", "Swift", 2023, "Red", 2500.0, "Petrol", 11.0));
            cars.add(new Car("C02", "Hyundai", "Creta", 2022, "White", 3500.0, "Diesel", 14.0));
            cars.add(new Car("C03", "Tata", "NexonEV", 2024, "Blue", 4000.0, "Electric", 15.0));
            customers.add(new Customer("U01", "Modiji", "modi@example.com"));
            customers.add(new Customer("U02", "Rahul gandhi", "rahul@example.com"));
            bookingIdCounter = new AtomicInteger(100);
        }

        public List<Car> getAllCars() { return cars; }
        public List<Customer> getAllCustomers() { return customers; }
        public List<Booking> getAllBookings() { return bookings; }
        public Optional<Car> findCarById(String id) { return cars.stream().filter(c -> c.id.equalsIgnoreCase(id)).findFirst(); }
        public Optional<Car> findAvailableCarById(String id) { return cars.stream().filter(c -> c.id.equalsIgnoreCase(id) && c.isAvailable).findFirst(); }
        public Optional<Customer> findCustomerById(String id) { return customers.stream().filter(c -> c.id.equalsIgnoreCase(id)).findFirst(); }
        public Optional<Booking> findBookingById(String id) { return bookings.stream().filter(b -> b.id.equalsIgnoreCase(id)).findFirst(); }

        public String rentCar(String carId, String customerId) {
            Optional<Car> carOpt = findAvailableCarById(carId);
            if (!carOpt.isPresent()) return "Car not available or does not exist.";
            if (!findCustomerById(customerId).isPresent()) return "Customer does not exist.";
            carOpt.get().isAvailable = false;
            String bookingId = "B" + bookingIdCounter.incrementAndGet();
            bookings.add(new Booking(bookingId, carOpt.get(), findCustomerById(customerId).get()));
            return "Car rented successfully! Booking ID: " + bookingId;
        }

        public String returnCarAndCalculateCost(String bookingId, int daysRented, double kmDriven) {
            Optional<Booking> bookingOpt = findBookingById(bookingId);
            if (!bookingOpt.isPresent()) return "Error: Booking ID not found.";
            Booking booking = bookingOpt.get();
            Car car = booking.car;
            if (car.isAvailable) return "Error: This car has already been returned.";
            double fixedCost = daysRented * car.dailyRate;
            double mileageCost = kmDriven * car.perKmRate;
            double totalCost = fixedCost + mileageCost;
            car.isAvailable = true;
            bookings.remove(booking);
            return String.format("Return Successful!\n\nFixed Cost (%d days @ ₹%.2f/day): ₹%.2f\nMileage Cost (%.1f km @ ₹%.2f/km): ₹%.2f\n-------------------------------------------\nTOTAL COST: ₹%.2f",
                daysRented, car.dailyRate, fixedCost, kmDriven, car.perKmRate, mileageCost, totalCost);
        }
        
        public String deleteCustomerById(String customerId) {
            Optional<Customer> custOpt = findCustomerById(customerId);
            if (!custOpt.isPresent()) return "Customer not found.";
            boolean hasActiveBooking = bookings.stream().anyMatch(b -> b.customer.id.equalsIgnoreCase(customerId));
            if (hasActiveBooking) return "Error: Customer cannot be deleted as they have an active rental.";
            customers.remove(custOpt.get());
            return "Customer " + custOpt.get().name + " deleted successfully.";
        }
    }
    
    private static class EntryScreen extends JWindow {
        private final JProgressBar progressBar;
        public EntryScreen() {
            setSize(500, 300); setLocationRelativeTo(null);
            JPanel contentPanel = new JPanel(new BorderLayout()); contentPanel.setBackground(ColorTheme.BACKGROUND);
            contentPanel.setBorder(BorderFactory.createLineBorder(ColorTheme.ACCENT_COLOR, 2));
